# =============================================================================
# .env.example  –  Chatwoot tenant: empresa3
#
# Copy this file to .env and fill in every value.
# Do NOT commit .env to version control.
#
# When copying this directory to create a new tenant, update:
#   TENANT_SLUG, DOMAIN, FRONTEND_URL, POSTGRES_DATABASE, MAILER_SENDER_EMAIL
#   SECRET_KEY_BASE, ACTIVE_RECORD_ENCRYPTION_* (must be unique per tenant)
# =============================================================================

# ---------------------------------------------------------------------------
# Tenant identity  (change both when duplicating this directory)
# ---------------------------------------------------------------------------
# Unique slug — used for container names and Traefik router/service names.
# Must contain only lowercase letters, digits, and hyphens.
TENANT_SLUG=empresa3

# Public hostname routed by Traefik (must match your DNS A record).
DOMAIN=empresa3.chat.mysubdomain.com

# ---------------------------------------------------------------------------
# Chatwoot core
# ---------------------------------------------------------------------------
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true

# Must match DOMAIN above.
FRONTEND_URL=https://empresa3.chat.mysubdomain.com

# Unique 128-char hex key — generate with: openssl rand -hex 64
SECRET_KEY_BASE=CHANGE_ME_SECRET_KEY_BASE

# ---------------------------------------------------------------------------
# Database  (shared PostgreSQL cluster, dedicated database per tenant)
# POSTGRES_HOST must match the container_name in infra/docker-compose.yml.
# POSTGRES_PASSWORD must match POSTGRES_PASSWORD in infra/.env.
# ---------------------------------------------------------------------------
POSTGRES_HOST=chatwoot_postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot_empresa3
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ---------------------------------------------------------------------------
# Redis  (shared instance)
# Password must match REDIS_PASSWORD in infra/.env.
# ---------------------------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@chatwoot_redis:6379/0

# ---------------------------------------------------------------------------
# Active Record Encryption (Rails 7+)
# These three keys must be unique per tenant.
# Generate with: openssl rand -hex 32  (run once per key)
# ---------------------------------------------------------------------------
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=CHANGE_ME
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=CHANGE_ME

# ---------------------------------------------------------------------------
# E-mail (SMTP)
# ---------------------------------------------------------------------------
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_SENDER_EMAIL=Empresa3 Support <support@example.com>

# ---------------------------------------------------------------------------
# Optional: S3-compatible object storage (default is local disk)
# ---------------------------------------------------------------------------
# STORAGE_PROVIDER=amazon
# STORAGE_ACCESS_KEY_ID=CHANGE_ME
# STORAGE_SECRET_ACCESS_KEY=CHANGE_ME
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET_NAME=chatwoot-empresa3
