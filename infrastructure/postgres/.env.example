# =============================================================================
# infrastructure/postgres/.env.example  –  PostgreSQL secrets
#
# Copy this file to .env and fill in every value.
# Do NOT commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL  (shared cluster)
# ---------------------------------------------------------------------------
# Superuser name for the PostgreSQL cluster.
# Every company connects as this user — do NOT change per company.
POSTGRES_USERNAME=chatwoot

# Strong password — generate with: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD
