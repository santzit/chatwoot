# =============================================================================
# infrastructure/traefik/.env.example  –  Traefik secrets
#
# Copy this file to .env and fill in every value.
# Do NOT commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Let's Encrypt / ACME — TLS certificate registration
# ---------------------------------------------------------------------------
# Your real e-mail address. Let's Encrypt sends certificate expiry notices
# to this address. MUST NOT be an @example.com address — ACME will reject it.
ACME_EMAIL=your-email@yourdomain.com
