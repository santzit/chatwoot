# =============================================================================
# evolution.env.example  –  Evolution API configuration (v0.2x)
#
# Copy to evolution.env and fill in every value.
# Do NOT commit evolution.env to version control.
#
# Reference: https://doc.evolution-api.com/v2/pt/get-started/introduction
#
# Note: SERVER_URL is injected at runtime by docker-compose.yml as
#   https://evo.<DOMAIN>  — do not set it here.
#
# Important: The evolution database must exist before starting this service.
#   See README.md § "First-time setup" for the one-line creation command.
# =============================================================================

# ---------------------------------------------------------------------------
# Authentication
#
# Master API key for Evolution API.  Keep this secret.
# Generate with:  openssl rand -hex 32
# ---------------------------------------------------------------------------
AUTHENTICATION_API_KEY=CHANGE_ME_EVOLUTION_API_KEY

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
#
# Dedicated database for Evolution API.
# URI format: postgresql://<user>:<password>@<host>:<port>/<database>
# Use the same POSTGRES_USERNAME and POSTGRES_PASSWORD as .env.
# The evolution database must be created manually once — see README.md.
# ---------------------------------------------------------------------------
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://CHANGE_ME_POSTGRES_USERNAME:CHANGE_ME_POSTGRES_PASSWORD@chatwoot_postgres:5432/evolution
DATABASE_CONNECTION_CLIENT_NAME=evolution
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# ---------------------------------------------------------------------------
# Cache (Redis, DB index 1)
#
# Uses DB index 1 to avoid key-space collisions with Chatwoot (index 0).
# REDIS_PASSWORD must match REDIS_PASSWORD in .env.
# ---------------------------------------------------------------------------
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:CHANGE_ME_SAME_AS_ENV_REDIS_PASSWORD@chatwoot_redis:6379/1
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# ---------------------------------------------------------------------------
# Chatwoot integration
#
# Must be true for Evolution API to accept Chatwoot connections.
# Per-instance Chatwoot URL, Account ID, and Token are configured when
# creating or updating a WhatsApp instance via the Evolution API.
# ---------------------------------------------------------------------------
CHATWOOT_ENABLED=true

# ---------------------------------------------------------------------------
# Behaviour defaults
# ---------------------------------------------------------------------------
# Keep instances alive across container restarts.
DEL_INSTANCE=false
