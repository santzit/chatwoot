# =============================================================================
# evolution.env.example  –  Evolution API configuration (v0.2x)
#
# Copy to evolution.env and fill in every value.
# Do NOT commit evolution.env to version control.
#
# Reference: https://doc.evolution-api.com/v2/pt/get-started/introduction
#
# Note: SERVER_URL is injected at runtime by docker-compose.yml as
#   https://evo.<DOMAIN>  — do not set it here.
#
# Evolution API v2 always requires PostgreSQL (Prisma-managed schema).
# This stack shares the existing chatwoot postgres container — no new
# database container is needed.
# =============================================================================

# ---------------------------------------------------------------------------
# Authentication
#
# Master API key for Evolution API.  Keep this secret.
# Generate with:  openssl rand -hex 32
# ---------------------------------------------------------------------------
AUTHENTICATION_API_KEY=CHANGE_ME_EVOLUTION_API_KEY

# ---------------------------------------------------------------------------
# Chatwoot integration
#
# Must be true for Evolution API to accept Chatwoot connections.
# Per-instance Chatwoot URL, Account ID, and Token are configured when
# creating or updating a WhatsApp instance via the Evolution API.
# ---------------------------------------------------------------------------
CHATWOOT_ENABLED=true

# ---------------------------------------------------------------------------
# Behaviour defaults
# ---------------------------------------------------------------------------
# Keep instances alive across container restarts.
DEL_INSTANCE=false

# ---------------------------------------------------------------------------
# Database
#
# Evolution API v2 requires a PostgreSQL database.  Use the existing Chatwoot
# postgres container — the evolution_api schema is kept fully isolated from
# Chatwoot tables (different Prisma schema namespace).
#
# Replace CHANGE_ME_POSTGRES_PASSWORD with the same value as in .env.
# ---------------------------------------------------------------------------
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://chatwoot:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/chatwoot_production?schema=evolution_api
DATABASE_CONNECTION_CLIENT_NAME=evolution_api

# ---------------------------------------------------------------------------
# Cache
#
# Disable Redis cache for evolution-api (use in-process local cache instead).
# This avoids connecting evolution-api to the chatwoot redis instance.
# ---------------------------------------------------------------------------
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true
