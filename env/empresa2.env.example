# =============================================================================
# env/empresa2.env.example  –  Chatwoot instance: empresa2
#
# Copy this file to env/empresa2.env and fill in every value.
# Do NOT commit env/empresa2.env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true

# Public URL of this Chatwoot instance (must match the Traefik router rule).
FRONTEND_URL=https://empresa2.chat.mysubdomain.com

# Random 64-byte hex key – generate with: openssl rand -hex 64
SECRET_KEY_BASE=CHANGE_ME_SECRET_KEY_BASE_EMPRESA2

# ---------------------------------------------------------------------------
# Database  (shared PostgreSQL cluster, dedicated database)
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot_empresa2

# Must match POSTGRES_USERNAME / POSTGRES_PASSWORD in .env
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ---------------------------------------------------------------------------
# Redis  (shared instance)
# Must match REDIS_PASSWORD in .env
# ---------------------------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@redis:6379/0

# ---------------------------------------------------------------------------
# Active Record Encryption (Rails 7+)
# Generate all three with: bin/rails db:encryption:init
# ---------------------------------------------------------------------------
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=CHANGE_ME
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=CHANGE_ME

# ---------------------------------------------------------------------------
# E-mail (SMTP) – required to send notifications, password-reset links, etc.
# ---------------------------------------------------------------------------
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_SENDER_EMAIL=Empresa2 Support <support@example.com>

# ---------------------------------------------------------------------------
# Optional: Storage (default is local disk; uncomment for S3-compatible)
# ---------------------------------------------------------------------------
# STORAGE_PROVIDER=amazon
# STORAGE_ACCESS_KEY_ID=CHANGE_ME
# STORAGE_SECRET_ACCESS_KEY=CHANGE_ME
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET_NAME=chatwoot-empresa2
