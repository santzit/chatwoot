# =============================================================================
# .gitignore  –  Exclude secrets and generated files from version control
# =============================================================================

# ---------------------------------------------------------------------------
# Actual secret env files (commit only the .example counterparts)
# ---------------------------------------------------------------------------
.env
empresa*/.env

# ---------------------------------------------------------------------------
# Traefik – Let's Encrypt certificate store (contains private keys)
# ---------------------------------------------------------------------------
traefik/acme.json

# ---------------------------------------------------------------------------
# OS / editor artifacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
