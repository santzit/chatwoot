# =============================================================================
# .gitignore  –  Exclude secrets and generated files from version control
# =============================================================================

# ---------------------------------------------------------------------------
# Infrastructure secrets (commit only the .env.example counterparts)
# ---------------------------------------------------------------------------
infrastructure/traefik/.env
infrastructure/traefik/acme.json
infrastructure/postgres/.env
infrastructure/redis/.env

# ---------------------------------------------------------------------------
# Company env files — actual secrets, never commit
# (The companies/ directory itself is tracked via companies/.gitkeep)
# ---------------------------------------------------------------------------
companies/*.env

# ---------------------------------------------------------------------------
# Backup files
# ---------------------------------------------------------------------------
backups/*.sql.gz
backups/*.sql

# ---------------------------------------------------------------------------
# OS / editor artifacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
