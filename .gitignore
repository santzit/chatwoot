# =============================================================================
# .gitignore  –  Exclude secrets and generated files from version control
# =============================================================================

# ---------------------------------------------------------------------------
# v0.2x simplified deployment — actual secrets (commit only *.example files)
# ---------------------------------------------------------------------------
.env
chatwoot.env
evolution.env
acme.json

# ---------------------------------------------------------------------------
# v0.1x legacy — infrastructure secrets
# ---------------------------------------------------------------------------
infra/.env
infra/acme.json

# ---------------------------------------------------------------------------
# v0.1x legacy — company env files
# (The companies/ directory itself is tracked via companies/.gitkeep)
# ---------------------------------------------------------------------------
companies/*.env

# ---------------------------------------------------------------------------
# Backup files
# ---------------------------------------------------------------------------
backups/*.sql.gz
backups/*.sql

# ---------------------------------------------------------------------------
# OS / editor artifacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
