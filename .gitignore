# =============================================================================
# .gitignore  –  Exclude secrets and generated files from version control
# =============================================================================

# ---------------------------------------------------------------------------
# Actual secret env files (use the .example counterparts instead)
# ---------------------------------------------------------------------------
.env
env/empresa1.env
env/empresa2.env
env/empresa3.env

# ---------------------------------------------------------------------------
# Traefik – Let's Encrypt certificate store (contains private keys)
# ---------------------------------------------------------------------------
traefik/acme.json

# ---------------------------------------------------------------------------
# OS / editor artifacts
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
