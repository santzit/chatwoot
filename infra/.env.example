# =============================================================================
# infra/.env.example  –  Shared infrastructure secrets
#
# Copy this file to .env and fill in every value.
# Do NOT commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Let's Encrypt / ACME  –  TLS certificate registration
# ---------------------------------------------------------------------------
# Your real e-mail address. Let's Encrypt sends certificate expiry notices
# to this address.
#
# RULES:
#   • MUST be a plain address — no display name, no angle brackets.
#     ✔  ACME_EMAIL=you@yourdomain.com
#     ✖  ACME_EMAIL=Your Name <you@yourdomain.com>   ← causes "unable to parse email address"
#     ✖  ACME_EMAIL=                                 ← causes "unable to parse email address"
#     ✖  ACME_EMAIL=CHANGE_ME@example.com            ← causes "forbidden domain example.com"
ACME_EMAIL=CHANGE_ME_your-real-email@yourdomain.com

# ---------------------------------------------------------------------------
# PostgreSQL  –  shared cluster
# ---------------------------------------------------------------------------
# Superuser for the PostgreSQL cluster.
# Every company connects as this user — do NOT change per company.
POSTGRES_USERNAME=chatwoot

# Strong password — generate with: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ---------------------------------------------------------------------------
# Redis  –  shared instance
# ---------------------------------------------------------------------------
# Strong password — generate with: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
