# =============================================================================
# chatwoot-template/example_evo.env  –  Evolution API environment template
#
# How to use:
#   The script scripts/create-company.sh copies this file to
#   companies/<company>_evo.env and substitutes the marked values automatically.
#
#   To create a company manually:
#     cp chatwoot-template/example_evo.env companies/mycompany_evo.env
#     # Edit companies/mycompany_evo.env:
#     #   AUTHENTICATION_API_KEY, DATABASE_CONNECTION_URI, CACHE_REDIS_URI,
#     #   DATABASE_CONNECTION_CLIENT_NAME, and CACHE_REDIS_PREFIX_KEY.
#
# Note: SERVER_URL is injected by docker-compose.yml at runtime as
#   https://evo.<DOMAIN> so it does not live in this file.
# =============================================================================

# ---------------------------------------------------------------------------
# Evolution API authentication
#
# AUTHENTICATION_API_KEY  – master API key for Evolution API.
#   Generate with:  openssl rand -hex 32
# ---------------------------------------------------------------------------
AUTHENTICATION_API_KEY=CHANGE_ME_EVOLUTION_API_KEY

# ---------------------------------------------------------------------------
# Evolution API database  (shared Postgres cluster, dedicated database)
#
# DATABASE_CONNECTION_URI  – PostgreSQL connection URI for Evolution API.
#   Uses the shared cluster (chatwoot_postgres) with a dedicated database
#   (evolution_<company>) created by scripts/create-company.sh.
# ---------------------------------------------------------------------------
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://chatwoot:CHANGE_ME_STRONG_POSTGRES_PASSWORD@chatwoot_postgres:5432/evolution_mycompany
DATABASE_CONNECTION_CLIENT_NAME=evolution_mycompany
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# ---------------------------------------------------------------------------
# Evolution API cache  (shared Redis, DB index 1)
#
# CACHE_REDIS_URI password must match REDIS_PASSWORD in infra/.env.
# Uses DB index 1 to avoid key-space collisions with Chatwoot (index 0).
# The per-company prefix (CACHE_REDIS_PREFIX_KEY) provides additional
# isolation when multiple companies share the same Redis instance.
# ---------------------------------------------------------------------------
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@chatwoot_redis:6379/1
CACHE_REDIS_PREFIX_KEY=evolution_mycompany
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# ---------------------------------------------------------------------------
# Chatwoot integration
#
# CHATWOOT_ENABLED must be true for Evolution API to accept Chatwoot
# connections.  Without it, every attempt to link an instance to Chatwoot
# returns "Error: Chatwoot is disabled".
#
# The per-instance Chatwoot URL, Account ID, and User Token are configured
# at runtime when you create or update a WhatsApp instance via the Evolution
# API (either through its web UI or POST /instance/create).  The global
# settings below simply unlock the feature for all instances on this server.
# ---------------------------------------------------------------------------
CHATWOOT_ENABLED=true

# ---------------------------------------------------------------------------
# Evolution API behaviour defaults
# ---------------------------------------------------------------------------
DEL_INSTANCE=false
