# =============================================================================
# chatwoot-template/example.env  –  Company environment template
#
# How to use:
#   The script scripts/create-company.sh copies this file to
#   companies/<company>.env and substitutes the marked values automatically.
#
#   To create a company manually:
#     cp chatwoot-template/example.env companies/mycompany.env
#     # Edit companies/mycompany.env:
#     #   COMPANY_NAME, DOMAIN, POSTGRES_DATABASE, SECRET_KEY_BASE,
#     #   ACTIVE_RECORD_ENCRYPTION_* keys, POSTGRES_PASSWORD, REDIS_URL,
#     #   and SMTP settings.
# =============================================================================

# ---------------------------------------------------------------------------
# Company identity  (set by create-company.sh)
# ---------------------------------------------------------------------------
COMPANY_NAME=mycompany
DOMAIN=mycompany.chat.yourdomain.com

# ---------------------------------------------------------------------------
# Chatwoot core
# ---------------------------------------------------------------------------
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true

# ---------------------------------------------------------------------------
# Cryptographic secrets
# These MUST be unique per company — never reuse across companies.
#
# Generate with:
#   SECRET_KEY_BASE:  openssl rand -hex 64
#   Each encryption key: openssl rand -hex 32
# ---------------------------------------------------------------------------
SECRET_KEY_BASE=CHANGE_ME_SECRET_KEY_BASE
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME_DETERMINISTIC_KEY
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=CHANGE_ME_DERIVATION_SALT
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=CHANGE_ME_PRIMARY_KEY

# ---------------------------------------------------------------------------
# Database  (shared PostgreSQL cluster, one database per company)
# POSTGRES_HOST must match the container_name in infra/docker-compose.yml.
# POSTGRES_USERNAME must match POSTGRES_USERNAME in infra/.env.
# Changing POSTGRES_USERNAME to the company name causes:
#   FATAL: password authentication failed for user "<company>"
#   DETAIL: Role "<company>" does not exist.
# ---------------------------------------------------------------------------
POSTGRES_HOST=chatwoot_postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot_mycompany
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ---------------------------------------------------------------------------
# Redis  (shared instance)
# REDIS_PASSWORD must match REDIS_PASSWORD in infra/.env.
# ---------------------------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@chatwoot_redis:6379/0

# ---------------------------------------------------------------------------
# E-mail (SMTP)
#
# Chatwoot REQUIRES SMTP to send invitation/login/notification e-mails.
# Without a real SMTP relay, users will NOT receive any e-mails.
#
# Options (free tiers available):
#   • Resend     https://resend.com
#   • SendGrid   https://sendgrid.com
#   • Mailgun    https://mailgun.com
#   • Gmail SMTP (smtp.gmail.com:587, App Password required)
#
# MAILER_SENDER_EMAIL  – the "From" address. MUST be plain: user@domain.com
#   ✖  "Company Support <support@domain.com>"  ← can cause delivery issues
#   ✔  support@domain.com
# ---------------------------------------------------------------------------
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_DOMAIN=example.com
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_SENDER_EMAIL=support@example.com

# ---------------------------------------------------------------------------
# Optional: S3-compatible object storage (default is local disk)
# ---------------------------------------------------------------------------
# STORAGE_PROVIDER=amazon
# STORAGE_ACCESS_KEY_ID=CHANGE_ME
# STORAGE_SECRET_ACCESS_KEY=CHANGE_ME
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET_NAME=chatwoot-mycompany
