# =============================================================================
# chatwoot-template/example.env  –  Company environment template
#
# How to use:
#   The script scripts/create-company.sh copies this file to
#   companies/<company>.env and substitutes the marked values automatically.
#
#   To create a company manually:
#     cp chatwoot-template/example.env companies/mycompany.env
#     # Edit companies/mycompany.env:
#     #   COMPANY_NAME, DOMAIN, POSTGRES_DATABASE, SECRET_KEY_BASE,
#     #   ACTIVE_RECORD_ENCRYPTION_* keys, POSTGRES_PASSWORD, REDIS_URL,
#     #   SMTP settings, AUTHENTICATION_API_KEY, DATABASE_CONNECTION_URI,
#     #   and CACHE_REDIS_URI.
# =============================================================================

# ---------------------------------------------------------------------------
# Company identity  (set by create-company.sh)
# ---------------------------------------------------------------------------
COMPANY_NAME=mycompany
DOMAIN=mycompany.chat.yourdomain.com

# ---------------------------------------------------------------------------
# Chatwoot core
# ---------------------------------------------------------------------------
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true

# ---------------------------------------------------------------------------
# Cryptographic secrets
# These MUST be unique per company — never reuse across companies.
#
# Generate with:
#   SECRET_KEY_BASE:  openssl rand -hex 64
#   Each encryption key: openssl rand -hex 32
# ---------------------------------------------------------------------------
SECRET_KEY_BASE=CHANGE_ME_SECRET_KEY_BASE
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME_DETERMINISTIC_KEY
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=CHANGE_ME_DERIVATION_SALT
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=CHANGE_ME_PRIMARY_KEY

# ---------------------------------------------------------------------------
# Database  (shared PostgreSQL cluster, one database per company)
# POSTGRES_HOST must match the container_name in infra/docker-compose.yml.
# POSTGRES_USERNAME must match POSTGRES_USERNAME in infra/.env.
# Changing POSTGRES_USERNAME to the company name causes:
#   FATAL: password authentication failed for user "<company>"
#   DETAIL: Role "<company>" does not exist.
# ---------------------------------------------------------------------------
POSTGRES_HOST=chatwoot_postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot_mycompany
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ---------------------------------------------------------------------------
# Redis  (shared instance)
# REDIS_PASSWORD must match REDIS_PASSWORD in infra/.env.
# ---------------------------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@chatwoot_redis:6379/0

# ---------------------------------------------------------------------------
# E-mail (SMTP)
#
# Chatwoot REQUIRES SMTP to send invitation/login/notification e-mails.
# Without a real SMTP relay, users will NOT receive any e-mails.
#
# Options (free tiers available):
#   • Resend     https://resend.com
#   • SendGrid   https://sendgrid.com
#   • Mailgun    https://mailgun.com
#   • Gmail SMTP (smtp.gmail.com:587, App Password required)
#
# MAILER_SENDER_EMAIL  – the "From" address. MUST be plain: user@domain.com
#   ✖  "Company Support <support@domain.com>"  ← can cause delivery issues
#   ✔  support@domain.com
# ---------------------------------------------------------------------------
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_DOMAIN=example.com
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_SENDER_EMAIL=support@example.com

# ---------------------------------------------------------------------------
# Optional: S3-compatible object storage (default is local disk)
# ---------------------------------------------------------------------------
# STORAGE_PROVIDER=amazon
# STORAGE_ACCESS_KEY_ID=CHANGE_ME
# STORAGE_SECRET_ACCESS_KEY=CHANGE_ME
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET_NAME=chatwoot-mycompany

# ---------------------------------------------------------------------------
# Evolution API  (WhatsApp bridge — per-company instance)
#
# Evolution API runs as an internal-only container on chatwoot-net.
# It is NOT exposed to the internet — there is no public URL or Traefik
# routing for this service.
#
# Connectivity model:
#   • OUTBOUND to internet: Evolution API opens a persistent WebSocket to
#     WhatsApp servers (Baileys).  This works via the Docker default NAT
#     gateway with no extra configuration.
#   • INBOUND from Chatwoot: Chatwoot calls Evolution API using the internal
#     container hostname (chatwoot_<company>_evolution:8080).
#   • INBOUND from Evolution API to Chatwoot: Evolution API delivers incoming
#     WhatsApp messages to Chatwoot via the internal URL set in CHATWOOT_URL
#     when configuring an instance (http://chatwoot_<company>_web:3000).
#
# AUTHENTICATION_API_KEY  – master API key for Evolution API.
#   Generate with:  openssl rand -hex 32
#
# DATABASE_CONNECTION_URI  – PostgreSQL connection URI for Evolution API.
#   Uses the shared cluster (chatwoot_postgres) with a dedicated database
#   (evolution_<company>) created by scripts/create-company.sh.
#
# CACHE_REDIS_URI  – Redis connection for Evolution API session cache.
#   Uses DB index 1 to avoid key-space collisions with Chatwoot (index 0).
#   The per-company prefix (CACHE_REDIS_PREFIX_KEY) provides additional
#   isolation when multiple companies share the same Redis instance.
# ---------------------------------------------------------------------------
AUTHENTICATION_API_KEY=CHANGE_ME_EVOLUTION_API_KEY

# --- Evolution API database (shared Postgres cluster, dedicated database) ---
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://chatwoot:CHANGE_ME_STRONG_POSTGRES_PASSWORD@chatwoot_postgres:5432/evolution_mycompany
DATABASE_CONNECTION_CLIENT_NAME=evolution_mycompany
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# --- Evolution API cache (shared Redis, DB index 1) -------------------------
# CACHE_REDIS_URI password must match REDIS_PASSWORD in infra/.env.
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@chatwoot_redis:6379/1
CACHE_REDIS_PREFIX_KEY=evolution_mycompany
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# --- Evolution API behaviour defaults ---------------------------------------
DEL_INSTANCE=false
