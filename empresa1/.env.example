# =============================================================================
# .env.example  –  Chatwoot tenant: empresa1
#
# Copy this file to .env and fill in every value.
# Do NOT commit .env to version control.
#
# When duplicating this directory to create a new tenant, you only need to
# change the following values:
#   TENANT_SLUG         – unique short name for this tenant
#   POSTGRES_DATABASE   – unique database name (chatwoot_<new_slug>)
#   SECRET_KEY_BASE     – generate with: openssl rand -hex 64
#   ACTIVE_RECORD_ENCRYPTION_*  – generate each with: openssl rand -hex 32
#
# BASE_DOMAIN, Postgres/Redis credentials, and SMTP settings can be reused
# from the source directory unchanged.
# =============================================================================

# ---------------------------------------------------------------------------
# Tenant identity
# ---------------------------------------------------------------------------
# Unique slug — used for container names and Traefik router/service names.
# Must contain only lowercase letters, digits, and hyphens.
TENANT_SLUG=empresa1

# Base domain shared by all tenants.
# The full public URL is assembled automatically as: https://TENANT_SLUG.BASE_DOMAIN
# You do NOT need to set FRONTEND_URL — it is derived in docker-compose.yml.
BASE_DOMAIN=chat.mysubdomain.com

# ---------------------------------------------------------------------------
# Chatwoot core
# ---------------------------------------------------------------------------
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true

# Unique 128-char hex key — generate with: openssl rand -hex 64
SECRET_KEY_BASE=CHANGE_ME_SECRET_KEY_BASE

# ---------------------------------------------------------------------------
# Database  (shared PostgreSQL cluster, dedicated database per tenant)
# POSTGRES_HOST must match the container_name in the root docker-compose.yml.
# POSTGRES_PASSWORD must match POSTGRES_PASSWORD in the root .env.
# ---------------------------------------------------------------------------
POSTGRES_HOST=chatwoot_postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot_empresa1
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ---------------------------------------------------------------------------
# Redis  (shared instance)
# Password must match REDIS_PASSWORD in the root .env.
# ---------------------------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME_STRONG_REDIS_PASSWORD@chatwoot_redis:6379/0

# ---------------------------------------------------------------------------
# Active Record Encryption (Rails 7+)
# These three keys must be unique per tenant.
# Generate with: openssl rand -hex 32  (run once per key)
# ---------------------------------------------------------------------------
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=CHANGE_ME
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=CHANGE_ME

# ---------------------------------------------------------------------------
# E-mail (SMTP)
# ---------------------------------------------------------------------------
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_SENDER_EMAIL=Empresa1 Support <support@example.com>

# ---------------------------------------------------------------------------
# Optional: S3-compatible object storage (default is local disk)
# ---------------------------------------------------------------------------
# STORAGE_PROVIDER=amazon
# STORAGE_ACCESS_KEY_ID=CHANGE_ME
# STORAGE_SECRET_ACCESS_KEY=CHANGE_ME
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET_NAME=chatwoot-empresa1
