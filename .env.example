# =============================================================================
# .env.example  –  Infrastructure configuration (v0.2x)
#
# Copy to .env and fill in every value.
# Do NOT commit .env to version control.
#
# This file configures shared infrastructure (Traefik, PostgreSQL, Redis).
# Chatwoot application variables live in chatwoot.env.
# =============================================================================

# ---------------------------------------------------------------------------
# Public domain
#
# Base hostname. Chatwoot will be reachable at app.<DOMAIN>.
# DNS A record for app.<DOMAIN> must point to this server's IP.
#
#   ✔  DOMAIN=chat.yourdomain.com
#   ✖  DOMAIN=https://chat.yourdomain.com   (no protocol prefix)
#
# The default "localhost" works for local testing and CI.
# Replace with your real domain before going to production.
# ---------------------------------------------------------------------------
DOMAIN=localhost

# ---------------------------------------------------------------------------
# Let's Encrypt / ACME  –  TLS certificate registration
#
# Must be a plain e-mail address.
#   ✔  ACME_EMAIL=you@yourdomain.com
#   ✖  ACME_EMAIL=Your Name <you@yourdomain.com>
# ---------------------------------------------------------------------------
ACME_EMAIL=you@example.com

# ---------------------------------------------------------------------------
# PostgreSQL  –  superuser credentials
#
# POSTGRES_USER is used by the postgres container to create the initial user.
# chatwoot.env must set POSTGRES_USERNAME to the same value.
# Replace the password with a strong secret before going to production:
#   openssl rand -hex 32
# ---------------------------------------------------------------------------
POSTGRES_USER=chatwoot
POSTGRES_PASSWORD=testpass

# ---------------------------------------------------------------------------
# Redis  –  shared instance password
#
# chatwoot.env must use this same password in REDIS_URL.
# Replace with a strong secret before going to production:
#   openssl rand -hex 32
# ---------------------------------------------------------------------------
REDIS_PASSWORD=testredis
