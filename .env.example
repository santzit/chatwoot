# =============================================================================
# .env.example  –  Shared infrastructure configuration (v0.2x)
#
# Copy to .env and fill in every value.
# Do NOT commit .env to version control.
#
# This file configures the infrastructure services (Traefik, PostgreSQL, Redis)
# and the DOMAIN variable that binds all services together.
# Application-specific variables live in chatwoot.env and evolution.env.
# =============================================================================

# ---------------------------------------------------------------------------
# Public domain
#
# Base hostname for the deployment. Must have DNS A records pointing to this
# server for both subdomains:
#   • app.<DOMAIN>  →  Chatwoot (e.g. app.chat.yourdomain.com)
#   • evo.<DOMAIN>  →  Evolution API (e.g. evo.chat.yourdomain.com)
#
#   ✔  DOMAIN=chat.yourdomain.com
#   ✖  DOMAIN=https://chat.yourdomain.com   (no protocol prefix)
#   ✖  DOMAIN=                              (must not be empty)
# ---------------------------------------------------------------------------
DOMAIN=chat.yourdomain.com

# ---------------------------------------------------------------------------
# Let's Encrypt / ACME  –  TLS certificate registration
#
# Must be a plain e-mail address (no display name, no angle brackets).
#   ✔  ACME_EMAIL=you@yourdomain.com
#   ✖  ACME_EMAIL=Your Name <you@yourdomain.com>
#   ✖  ACME_EMAIL=CHANGE_ME@example.com     (example.com is rejected by ACME)
# ---------------------------------------------------------------------------
ACME_EMAIL=you@yourdomain.com

# ---------------------------------------------------------------------------
# PostgreSQL  –  superuser credentials for the shared cluster
#
# Both chatwoot.env and evolution.env must use these same credentials.
# Generate password with:  openssl rand -hex 32
# ---------------------------------------------------------------------------
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ---------------------------------------------------------------------------
# Redis  –  shared instance
#
# Both chatwoot.env and evolution.env must use this same password.
# Generate with:  openssl rand -hex 32
# ---------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
