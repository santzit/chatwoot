# =============================================================================
# .env.example  –  Shared infrastructure secrets
#
# Copy this file to .env and fill in every value.
# Do NOT commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Let's Encrypt / ACME — TLS certificate registration
# ---------------------------------------------------------------------------
# Your real e-mail address.  Let's Encrypt uses this to notify you about
# expiring certificates.  MUST NOT contain "example.com" or ACME will reject
# the account registration.
ACME_EMAIL=your-email@yourdomain.com

# ---------------------------------------------------------------------------
# PostgreSQL  (shared cluster)
# ---------------------------------------------------------------------------
# Superuser name for the PostgreSQL cluster.
POSTGRES_USERNAME=chatwoot

# Strong password — generate with: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ---------------------------------------------------------------------------
# Redis  (shared instance)
# ---------------------------------------------------------------------------
# Strong password — generate with: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
