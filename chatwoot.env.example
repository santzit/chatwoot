# =============================================================================
# chatwoot.env.example  –  Chatwoot application configuration (v0.2x)
#
# Copy to chatwoot.env and fill in every value.
# Do NOT commit chatwoot.env to version control.
#
# Reference: https://developers.chatwoot.com/introduction
#
# Note: FRONTEND_URL is injected at runtime by docker-compose.yml as
#   https://<DOMAIN>  — do not set it here.
# =============================================================================

# ---------------------------------------------------------------------------
# Rails runtime
# ---------------------------------------------------------------------------
RAILS_ENV=production
RAILS_LOG_TO_STDOUT=true

# ---------------------------------------------------------------------------
# Cryptographic secrets  (unique per deployment — never reuse)
#
# Generate with:
#   SECRET_KEY_BASE:               openssl rand -hex 64
#   Each ACTIVE_RECORD_ENCRYPTION key:  openssl rand -hex 32
# ---------------------------------------------------------------------------
SECRET_KEY_BASE=CHANGE_ME_SECRET_KEY_BASE
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME_DETERMINISTIC_KEY
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=CHANGE_ME_DERIVATION_SALT
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=CHANGE_ME_PRIMARY_KEY

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
#
# POSTGRES_HOST must match the container_name in docker-compose.yml.
# POSTGRES_USERNAME and POSTGRES_PASSWORD must match .env.
# POSTGRES_DATABASE is created automatically by the postgres service on first
# start (via POSTGRES_DB in docker-compose.yml) — no manual creation needed.
# ---------------------------------------------------------------------------
POSTGRES_HOST=chatwoot_postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=CHANGE_ME_SAME_AS_ENV_POSTGRES_USERNAME
POSTGRES_PASSWORD=CHANGE_ME_SAME_AS_ENV_POSTGRES_PASSWORD

# ---------------------------------------------------------------------------
# Redis (shared instance, DB index 0)
#
# REDIS_PASSWORD must match REDIS_PASSWORD in .env.
# Uses DB 0; Evolution API uses DB 1 to avoid key-space collisions.
# ---------------------------------------------------------------------------
REDIS_URL=redis://:CHANGE_ME_SAME_AS_ENV_REDIS_PASSWORD@chatwoot_redis:6379/0

# ---------------------------------------------------------------------------
# E-mail (SMTP)
#
# Chatwoot requires SMTP to send invitation, password-reset, and notification
# e-mails.  Without a real SMTP relay users will not receive any e-mails.
#
# Free options: Resend (https://resend.com), SendGrid, Mailgun,
#               Gmail App Password (smtp.gmail.com:587).
#
# MAILER_SENDER_EMAIL must be a plain address (no display name):
#   ✔  support@yourdomain.com
#   ✖  "Support <support@yourdomain.com>"
# ---------------------------------------------------------------------------
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_DOMAIN=yourdomain.com
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_SENDER_EMAIL=support@yourdomain.com

# ---------------------------------------------------------------------------
# Optional: S3-compatible object storage (default: local disk via Docker volume)
# ---------------------------------------------------------------------------
# STORAGE_PROVIDER=amazon
# STORAGE_ACCESS_KEY_ID=CHANGE_ME
# STORAGE_SECRET_ACCESS_KEY=CHANGE_ME
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET_NAME=chatwoot
