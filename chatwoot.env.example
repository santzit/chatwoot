# =============================================================================
# chatwoot.env.example  –  Chatwoot application configuration (v0.2x)
#
# Copy to chatwoot.env and fill in every value.
# Do NOT commit chatwoot.env to version control.
#
# Reference: https://developers.chatwoot.com/self-hosted/deployment/docker
#
# Note: FRONTEND_URL is injected at runtime by docker-compose.yml from DOMAIN.
#       NODE_ENV, RAILS_ENV, INSTALLATION_ENV are also set by docker-compose.yml.
# =============================================================================

# ---------------------------------------------------------------------------
# Cryptographic secrets  (regenerate unique values per deployment — never reuse)
#
# These example values work for local testing and CI.
# Before going to production, replace every value below with freshly generated
# secrets using:
#   SECRET_KEY_BASE:                        openssl rand -hex 64
#   ACTIVE_RECORD_ENCRYPTION_* keys:        openssl rand -hex 32
# ---------------------------------------------------------------------------
SECRET_KEY_BASE=37cb357f3394c8285b90026336ca3783cf66b3116646fe5e3d9dff93edca0cdd7ab4d4e7057b9488abea10e6a2648beea9eb7a2cd683dc83491265d5367e3f49
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=f27eac3f621d57b0dd25a7de248b83632168fd706bf305e9c67d410c83a73432
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=0a2dc5ff72882ff335b8864ae54cd113c407606b6584cade354af88961677fc5
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=41d418aaf53f0c59ce3096a8b5790fcbab48cde6f23c2c00a02d5dfb5d535db6

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
#
# POSTGRES_HOST must be the service name defined in docker-compose.yml.
# NOTE: Chatwoot's Rails app expects POSTGRES_USERNAME (not POSTGRES_USER).
#       Set it to the same value as POSTGRES_USER in .env.
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot_production
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=testpass

# ---------------------------------------------------------------------------
# Redis
#
# Must match REDIS_PASSWORD in .env.
# ---------------------------------------------------------------------------
REDIS_URL=redis://:testredis@redis:6379/0

# ---------------------------------------------------------------------------
# E-mail (SMTP)
#
# For local testing and CI, SMTP_ADDRESS=localhost is fine (emails are dropped).
# Replace with your real SMTP provider settings before going to production.
# ---------------------------------------------------------------------------
SMTP_ADDRESS=localhost
SMTP_PORT=1025
SMTP_DOMAIN=yourdomain.com
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=changeme-smtp-password
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
MAILER_SENDER_EMAIL=support@yourdomain.com

# ---------------------------------------------------------------------------
# Account signup
#
# Set to true to allow new accounts to be created via the /auth/sign_up
# endpoint. Disabled by default in self-hosted deployments for security.
# ---------------------------------------------------------------------------
ENABLE_ACCOUNT_SIGNUP=false
